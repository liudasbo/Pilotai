{
  "name": "pilotai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:test": "next start -p 3000",
    "lint": "eslint . --ext .js --max-warnings=0",
