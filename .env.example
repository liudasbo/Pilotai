# Hostinger SMTP settings for contact/newsletter email delivery.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Sender/receiver mailbox (receiver defaults to info@pilotaiprogram.com).
MAIL_FROM=
MAIL_TO=info@pilotaiprogram.com

# Optional social links shown in Header.
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=

# Local/dev fallback behavior for forms without SMTP config.
# Set to false to force SMTP requirement in all environments.
ALLOW_FORM_FALLBACK=true
